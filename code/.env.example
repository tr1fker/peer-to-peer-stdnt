# Copy to ".env" in this folder (next to docker-compose.yml) and fill in.
# Docker Compose reads .env automatically.
#
# 1) GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
# 2) Authorization callback URL (must match exactly how you open the app):
#    - Docker Compose as in this repo (browser → http://localhost:5173):
#        http://localhost:5173/login/oauth2/code/github
#    - Only Spring Boot in browser (API on 8080, no nginx on 5173):
#        http://localhost:8080/login/oauth2/code/github
# 3) Paste Client ID / Client secret below, then: docker compose up -d --build backend

GITHUB_CLIENT_ID=Ov23liGhmEy6fsn3FG4c
GITHUB_CLIENT_SECRET=7661a180872049a6e80d480fee6a6ae96da8ab82

# Where the backend redirects after GitHub login (must be the URL of your SPA /auth/callback).
# Docker Compose (this repo):  FRONTEND_OAUTH_REDIRECT=http://localhost:5173/auth/callback
# Pure Vite dev:                 FRONTEND_OAUTH_REDIRECT=http://localhost:5173/auth/callback

FRONTEND_OAUTH_REDIRECT=http://localhost:5173/auth/callback

# --- Google Sign-In (OAuth 2.0) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID → Web application.
#
# «Authorized JavaScript origins» — ТОЛЬКО origin, без пути и без «/» в конце:
#   http://localhost:5173
#   http://localhost:8080          (опционально, если открываете API с этого порта)
# Сюда НЕЛЬЗЯ вставлять /login/oauth2/code/google — Google так и пишет: «must not contain a path».
#
# «Authorized redirect URIs» — полный callback (именно сюда путь /login/oauth2/code/google):
#   http://localhost:5173/login/oauth2/code/google   — Vite dev или фронт в Docker на :5173
#   http://localhost:8080/login/oauth2/code/google   — если OAuth-редирект идёт прямо на Spring
# Добавьте оба redirect URI, если переключаетесь между способами запуска.
#
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Подтверждение email ---
# Ссылка в письме (адрес вашего фронта в браузере, без слэша в конце)
FRONTEND_BASE_URL=http://localhost:5173

# Чтобы письма РЕАЛЬНО уходили на почту, сделайте это САМИ (бот не знает ваш пароль):
# 1) Скопируйте этот файл в ".env" рядом с docker-compose.yml (если ещё не скопировали).
# 2) Раскомментируйте и заполните блок ниже. Для Gmail SPRING_MAIL_PASSWORD — это НЕ ваш обычный пароль от почты,
#    а 16 символов из раздела Google: Безопасность → двухэтапка → Пароли приложений (тип "Почта", устройство любое).
# 3) docker compose up -d --build backend   (или задайте те же переменные в IDE при запуске Spring).
# Пока переменные пустые — письмо не шлётся; ссылка подтверждения пишется в лог backend (WARN).
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=you@gmail.com
# SPRING_MAIL_PASSWORD=ваш-пароль-приложения-google
